{
  "version": 2,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/:path*/index.html",
      "destination": "/:path*",
      "permanent": true
    }
  ],
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "^/(manifest.json|sw.js|favicon.ico)$",
      "dest": "/website/$1"
    },
    {
      "src": "^/icons/(.*)$",
      "dest": "/public/icons/$1"
    },
    {
      "src": "/api/upload",
      "dest": "/api/upload.js"
    },
    {
      "src": "/api/transcribe",
      "dest": "/api/transcribe.js"
    },
    {
      "src": "/api/summarize",
      "dest": "/api/summarize.js"
    },
    {
      "src": "/api/tools-content",
      "dest": "/api/tools-content.js"
    },
    {
      "src": "/api/ping-google",
      "dest": "/api/ping-google.js"
    },
    {
      "src": "/api/growth/decision",
      "dest": "/api/growth-decision.js"
    },
    {
      "src": "/api/growth/track",
      "dest": "/api/growth-track.js"
    },
    {
      "src": "/api/retention",
      "dest": "/api/retention.js"
    },
    {
      "src": "/api/payment/create",
      "dest": "/api/payment-create.js"
    },
    {
      "src": "/api/payment/verify",
      "dest": "/api/payment-verify.js"
    },
    {
      "src": "/api/payment/callback",
      "dest": "/api/payment-callback.js"
    },
    {
      "src": "/api/payment/retry",
      "dest": "/api/payment-retry.js"
    },
    {
      "src": "/api/invoices",
      "dest": "/api/invoices.js"
    },
    {
      "src": "/api/invoices/(.*)",
      "dest": "/api/invoice-by-id.js"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/api/sitemap.js"
    },
    {
      "src": "/api/analytics",
      "dest": "/api/analytics.js"
    },
    {
      "src": "/api/leads",
      "dest": "/api/leads.js"
    },
    {
      "src": "/api/cron/conversion-emails",
      "dest": "/api/cron-conversion-emails.js"
    },
    {
      "src": "/api/user/profile",
      "dest": "/api/user-profile.js"
    },
    {
      "src": "/api/admin/users/(.*)",
      "dest": "/api/admin-users-manage.js"
    },
    {
      "src": "/api/admin",
      "dest": "/api/admin.js"
    },
    {
      "src": "/api/admin/login",
      "dest": "/api/admin-login.js"
    },
    {
      "src": "/api/admin/logout",
      "dest": "/api/admin-logout.js"
    },
    {
      "src": "/api/admin/auth/me",
      "dest": "/api/admin-auth-me.js"
    },
    {
      "src": "/api/admin/forgot-password",
      "dest": "/api/admin-forgot-password.js"
    },
    {
      "src": "/api/admin/reset-password",
      "dest": "/api/admin-reset-password.js"
    },
    {
      "src": "^/(.*\\.(js|css|png|jpg|jpeg|svg|json|ico))$",
      "dest": "/website/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/website/404.html",
      "status": 404
    }
  ],
  "crons": [
    {
      "path": "/api/cron/conversion-emails",
      "schedule": "*/15 * * * *"
    }
  ]
}

# Cloudflare Turnstile (contact form) — copy to .env and set real secret from Cloudflare dashboard
CF_TURNSTILE_SECRET=your_secret

# Transcription providers (fallback order: OpenAI → Groq → Deepgram → local scaffold)
OPENAI_API_KEY=
GROQ_API_KEY=
# Translation (/api/translate-srt): Groq first, OpenAI fallback
TRANSLATE_GROQ_MODEL=llama-3.3-70b-versatile
DEEPGRAM_API_KEY=
WHISPER_LOCAL_ENABLED=false
# Optional: admin GET /api/admin/providers with header x-internal-diag-key
INTERNAL_DIAG_KEY=

# Set ADMIN_DEBUG=true to include provider error details in API responses
ADMIN_DEBUG=false

# Viral MP4 export (/api/export-video) — FFmpeg burn-in with ASS subtitles
VIDEO_RENDER_CONCURRENCY=1
VIDEO_RENDER_TIMEOUT_MS=300000
VIDEO_RENDER_MAX_DURATION_SEC=180
VIDEO_RENDER_MAX_UPLOAD_BYTES=104857600
VIDEO_RENDER_JOB_TTL_MS=1800000

# Optional RunPod GPU worker (FFmpeg burn only; ASS still generated on VPS)
GPU_RENDER_ENABLED=0
GPU_RENDER_URL=https://your-runpod-host:8787
GPU_RENDER_TOKEN=
GPU_RENDER_ARTIFACT_BASE_URL=https://cutup.shop
GPU_RENDER_TIMEOUT_MS=600000
GPU_RENDER_ARTIFACT_TTL_MS=3600000

# GPU worker / NVENC (set on RunPod; VPS keeps libx264 when GPU_RENDER_ENABLED=0)
VIDEO_RENDER_VIDEO_CODEC=
GPU_RENDER_WORKER=0
VIDEO_RENDER_NVENC_PRESET=p4
VIDEO_RENDER_NVENC_CQ=23
VIDEO_RENDER_NVENC_CUDA_DECODE=1

# RunPod GPU worker auto-stop (idle 5 min → stop pod via REST API)
RUNPOD_API_KEY=
RUNPOD_POD_ID=

# Production infrastructure (rate limit, queue, cache, GPU guard)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_BURST_WINDOW_MS=10000
RATE_LIMIT_BURST_THRESHOLD=8
RATE_LIMIT_COOLDOWN_MIN_SEC=30
RATE_LIMIT_COOLDOWN_MAX_SEC=120
MAX_CONCURRENT_DOWNLOADS=2
MAX_CONCURRENT_TRANSCRIBES=1
CACHE_TTL_HOURS=24
GPU_GUARD_ENABLED=true
GPU_MEM_THRESHOLD_PCT=88
PROCESS_JOB_TIMEOUT_MS=120000

# Render timeline diagnostics (locate subtitle burn delay vs preview)
RENDER_TIMELINE_TRACE=1
RENDER_SUBTITLE_HARD_SYNC_TEST=0
RENDER_NORMALIZE_CFR_FPS=30
RENDER_NORMALIZE_PRESET=veryfast
RENDER_NORMALIZE_CRF=18
RENDER_FORCE_NORMALIZE=1

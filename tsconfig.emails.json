{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@emails/*": ["emails/*"],
      "@services/email/*": ["services/email/*"]
    }
  },
  "include": ["emails/**/*.ts", "emails/**/*.tsx", "services/email/**/*.ts"]
}
